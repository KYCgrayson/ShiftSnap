{
  "name": "shiftsnap",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Shift Schedule Recognition & Calendar Sync",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter @shiftsnap/mobile",
    "mobile:start": "pnpm --filter @shiftsnap/mobile start",
    "mobile:ios": "pnpm --filter @shiftsnap/mobile ios",
    "mobile:android": "pnpm --filter @shiftsnap/mobile android",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrate": "supabase db push",
    "supabase:generate-types": "supabase gen types typescript --local > packages/shared/src/types/database.ts",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "author": "Grayson",
  "license": "MIT",
  "dependencies": {
    "expo": "~54.0.36",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
