{
  "expo": {
    "name": "ShiftSnap",
    "slug": "shiftsnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "shiftsnap",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shiftsnap.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ShiftSnap needs camera access to scan your work schedule",
        "NSPhotoLibraryUsageDescription": "ShiftSnap needs photo library access to select schedule images",
        "NSCalendarsFullAccessUsageDescription": "ShiftSnap needs access to your calendar to sync shift schedules"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFBF7"
      },
      "package": "com.shiftsnap.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "ShiftSnap needs camera access to scan your work schedule"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ShiftSnap needs photo library access to select schedule images"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A9DAD"
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "ShiftSnap needs calendar access to sync your shift schedule"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
